# SPO — Environment Variables
# Copy this file to .env and fill in your values.

# ── Data ──────────────────────────────────────────────────────────────────────
# Root directory for all flat-file JSON data (default: ~/spo_data)
SPO_DATA_DIR=

# ── API ───────────────────────────────────────────────────────────────────────
# Backend URL used by the Streamlit frontend (api.py)
SPO_API_URL=http://localhost:8000

# ── Google Integration ────────────────────────────────────────────────────────
# Path to your Google service account JSON (for Drive + Docs APIs)
GOOGLE_SERVICE_ACCOUNT_FILE=

# ── NotebookLM Automation ─────────────────────────────────────────────────────
# Credentials used by notebooklm-py to log in via Playwright
SPO_NLM_EMAIL=
SPO_NLM_PASSWORD=
